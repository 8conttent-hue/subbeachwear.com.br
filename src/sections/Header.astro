---
import siteConfig from '../data/siteConfig.json';
import { getAllPosts } from '../lib/posts';

const { name, menu: baseMenu = [], social = {}, headerContrast = 'light' } = siteConfig;

// Buscar categorias REAIS do banco de dados (SSR)
let realCategories = [];
try {
  const allPosts = await getAllPosts() || [];
  realCategories = [...new Set(allPosts.map(p => p.category))].filter(Boolean);
} catch (e) {
  console.error('[Header-G Category Error]', e);
}

// Injetar categorias reais no item "Blog" do menu
const menu = baseMenu.map((item: any) => {
  if (item.label.toLowerCase() === 'blog' || item.href === '/blog') {
    return {
      ...item,
      children: realCategories.length
        ? realCategories.map(cat => ({
            label: cat,
            href: `/categoria/${cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-')}`
          }))
        : undefined,
    };
  }
  return item;
});
---
<header class="w-full z-[100] bg-white border-b border-gray-100 sticky top-0">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-3">
          <span class="text-2xl font-black text-dark tracking-tighter">
            {name}<span class="text-primary text-4xl">.</span>
          </span>
        </a>
      </div>

      <!-- Nav Desktop -->
      <nav class="hidden lg:flex items-center gap-1 h-20">
        {menu.map((item: any) => (
        item.children?.length ? (
          <div class="relative group h-full flex items-center">
            <button type="button" class="flex items-center gap-1 px-5 py-2 text-sm font-bold text-gray-500 group-hover:text-dark group-hover:bg-gray-50 rounded-lg transition-all cursor-pointer">
              {item.label}
              <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="absolute top-full left-0 z-[110] pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <div class="w-56 bg-white border border-gray-100 shadow-2xl rounded-xl py-2">
                <a href={item.href} class="block px-5 py-2 text-[10px] font-black text-primary uppercase tracking-widest border-b border-gray-50 mb-1">
                  Ver Tudo
                </a>
                {item.children.map((child: any) => (
                  <a href={child.href} class="block px-5 py-2.5 text-sm font-semibold text-gray-600 hover:text-primary hover:bg-gray-50 transition-colors">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
            <a
              href={item.href}
              class="px-5 py-2 text-sm font-bold text-gray-500 hover:text-dark hover:bg-gray-50 rounded-lg transition-all"
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-4">
        <!-- Search bar desktop -->
        <div class="hidden xl:flex items-center bg-gray-100 rounded-full px-4 py-2 w-64 group focus-within:ring-2 ring-primary/20 transition-all">
          <svg class="w-4 h-4 text-gray-400 group-focus-within:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text" placeholder="Pesquisar..." class="bg-transparent border-none focus:ring-0 text-xs text-gray-600 ml-2 w-full" />
        </div>

        <div class="flex items-center gap-2 border-l border-gray-100 pl-4">
          <a href="/blog" class="p-2 text-gray-400 hover:text-primary transition-colors">
             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </a>
          <a
            href="/contato"
            class="inline-flex items-center px-6 py-2.5 bg-primary text-white text-sm font-black rounded-full hover:shadow-lg hover:shadow-primary/30 transition-all"
          >
            Contato
          </a>
        </div>

        <!-- Mobile menu toggle -->
        <button id="menu-btn-g" class="lg:hidden p-2 text-dark" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu-g" class="hidden lg:hidden bg-gray-50 border-t border-gray-200 p-6 shadow-inner">
    <div class="space-y-3">
      {menu.map((item: any) => (
        <div>
          <a href={item.href} class="block text-lg font-bold text-gray-800 border-b border-gray-200 pb-2">{item.label}</a>
          {item.children?.length ? (
            <div class="pl-4 mt-2 space-y-2 border-l-2 border-gray-200">
              {item.children.map((child: any) => (
                <a href={child.href} class="block text-sm text-gray-600 hover:text-primary">{child.label}</a>
              ))}
            </div>
          ) : null}
        </div>
      ))}
      <div class="pt-4 flex flex-col gap-4">
        <input type="text" placeholder="Pesquisar site..." class="w-full px-4 py-3 rounded-xl border-gray-200 bg-white" />
        <a href="/contato" class="w-full py-4 bg-dark text-white text-center rounded-xl font-black uppercase tracking-widest">Falar Conosco</a>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById('menu-btn-g')?.addEventListener('click', () => {
    document.getElementById('mobile-menu-g')?.classList.toggle('hidden');
  });
</script>